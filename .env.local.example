# ── n8n Webhook ───────────────────────────────────────────
# The public URL of your n8n instance's analyze webhook
NEXT_PUBLIC_ANALYZE_WEBHOOK_URL=http://localhost:5678/webhook/analyze

# ── Mock Mode (set to "true" to bypass n8n during development) ──
NEXT_PUBLIC_USE_MOCK_ANALYZE=true

# ── Supabase ──────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
