# ── Dependencies ──────────────────────────────────────────
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── Next.js build output ──────────────────────────────────
/.next/
/out/
/build

# ── Testing ───────────────────────────────────────────────
/coverage

# ── Environment variables (NEVER commit these) ────────────
.env
.env.*
!.env.example
!.env.local.example

# ── Vercel ────────────────────────────────────────────────
.vercel

# ── TypeScript ────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ── OS / Editor ───────────────────────────────────────────
.DS_Store
*.pem
Thumbs.db
.idea/
.vscode/settings.json

# ── Logs ──────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── Python (stats-helper) ─────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
*.egg-info/
dist/
